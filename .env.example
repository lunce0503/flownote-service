# Root Docker Compose example.
# Copy to `.env` for local compose usage and fill private values locally.

POSTGRES_USER=flownote
POSTGRES_PASSWORD=change-me
POSTGRES_DB=flownote

# iOS/Android real devices must use the development PC LAN IP, not localhost.
# Example: HOST_LAN_IP=192.168.0.10
HOST_LAN_IP=localhost

# Host port published for the redis container. Only the host-side mapping;
# internal service-to-service calls always use redis:6379.
# Override when host 6379 is already taken by another project's redis.
# Example: REDIS_HOST_PORT=6380
REDIS_HOST_PORT=6379

NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL2=http://localhost:8080
VITE_CORE_API_URL=http://localhost:8080
VITE_AI_BASE_URL=http://localhost:8000
VITE_SYNC_API_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# S3-compatible object storage. Use Cloudflare R2 in production.
# Do not commit real access keys.
FLOWNOTE_STORAGE_ENDPOINT=
FLOWNOTE_STORAGE_BUCKET=
FLOWNOTE_STORAGE_REGION=auto
FLOWNOTE_STORAGE_ACCESS_KEY_ID=
FLOWNOTE_STORAGE_SECRET_ACCESS_KEY=
FLOWNOTE_STORAGE_PUBLIC_BASE_URL=

# Redis read-through cache for the largest canvas owned by this username.
FLOWNOTE_CANVAS_CACHE_TARGET_USERNAME=lunce
FLOWNOTE_CANVAS_CACHE_TTL=24h

MOBILE_CORE_API_URL=http://localhost:8080
MOBILE_AI_API_URL=http://localhost:8000
MOBILE_WEB_URL=http://localhost:5173
MOBILE_MIN_SUPPORTED_VERSION=1.0.0
# Comma-separated feature flags returned by /api/mobile/config.
MOBILE_ENABLED_FEATURES=webview,auth,tasks,notes,canvas,agent
EXPO_PUBLIC_WAS_URL=http://localhost:8080
